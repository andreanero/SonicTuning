# --- CMake Build Folders, Cache & Artifacts ---
# Removing the leading slashes allows builds in subdirectories to be ignored too
cmake-build/
cmake-build-*/
cmake-release-build/
cmake-release-build-*/
cmake-release-with-debug-info-build/
ninja-debug-build/
ninja-release-build/
vs-build/
xcode-build/
.cmake/
# Ignore compiler-generated binaries and objects
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll

# --- Dependency Managers (CPM / JUCE downloads) ---
CPM_Modules/
_deps/

# --- JUCE Specific & Compiled Formats ---
JuceLibraryCode/
*.vst3/
*.component/
*.app/
*.vst/
*.aax/

# --- IDEs & Editors ---
.idea/
.vscode/
*.swp

# --- OS-specific noise ---
.DS_Store
Thumbs.db

# --- Local credentials (never commit) ---
.git_local_repo_credentials
*.token
*credentials*